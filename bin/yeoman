#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON_BIN="$ROOT_DIR/.venv/bin/python3"

if [ ! -x "$PYTHON_BIN" ]; then
    printf 'Repo virtualenv missing: %s\n' "$PYTHON_BIN" >&2
    printf 'Run: cd %s && uv sync\n' "$ROOT_DIR" >&2
    exit 1
fi

export YEOMAN_LAUNCHER_PATH="$ROOT_DIR/bin/yeoman"
export YEOMAN_LAUNCHER_KIND="repo-wrapper"

exec "$PYTHON_BIN" -m yeoman.cli.commands "$@"
